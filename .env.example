# Copy to .env and fill in. The .env file is git-ignored — never commit real secrets.
#   cp .env.example .env

# Shared login password (required). Compose and the server refuse to start if
# unset. This is the only credential — use a long random string, e.g.:
#   openssl rand -base64 24
APP_PASSWORD=

# --- Optional: defaults are set in docker-compose.yml, override here if needed ---

# Address the host port binds to. Default 127.0.0.1 = only a local reverse
# proxy / Cloudflare Tunnel can reach it. Use 0.0.0.0 for direct LAN access.
# BIND_ADDR=127.0.0.1

# Keep at most this many items; oldest are pruned. 0 = unlimited.
# MAX_ITEMS=200

# Delete items older than this many days. 0 = never expire.
# MAX_AGE_DAYS=30

# Reject uploads larger than this (MB).
# MAX_UPLOAD_MB=100
